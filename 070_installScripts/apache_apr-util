#!/bin/bash

# DEPENDS:
#           script install ./apache_apr

tag=1.6.3

name=apr-util
tarname=${name}-$tag

set -exo pipefail

cd "$(dirname ${BASH_SOURCE[0]})"

try=0
tarnameTry=$tarname-try-$try
while [ -d "${tarnameTry}" ] ; do
    let try=$try+1
    tarnameTry=$tarname-try-$try
done
builddir="${tarnameTry}"


tarfile=$tarname.tar.bz2
url=https://dlcdn.apache.org/apr/${tarfile}

prefix=/usr/local/encap/$tarnameTry


sha512sum=

case "$tag" in
    fooo.4.5.5.5.5)
        sha512sum=
        ;;
esac


if [ ! -e "$tarfile" ] ; then
    wget --no-check-certificate $url -O $tarfile
fi


if [ -n "$sha512sum" ] ; then
    echo "$sha512sum  $tarfile" | sha512sum -c -
else
    set +x
    sha512sum $tarfile
    set -x
fi

mkdir "$builddir"
cd "$builddir"
tar --strip-components=1 -xjf ../$tarfile


./configure --prefix="${prefix}" --with-apr=/usr/local
make
make install



set +x

cat << EOF

   SUCCESSFULLY installed $tarname in $prefix

EOF

